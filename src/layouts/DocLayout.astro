---
import '../styles/global.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  currentSlug: string;
  headings?: Heading[];
}

const { title, currentSlug, headings = [] } = Astro.props;
const base = import.meta.env.BASE_URL;

const nav = [
  { label: 'Products', slug: 'guide', href: base + 'guide/', group: 'products' },
  { label: 'Nursery', slug: 'nursery', href: base + 'nursery/', group: 'products', indent: true },
  { label: 'Feeding', slug: 'feeding', href: base + 'feeding/', group: 'products', indent: true },
  { label: 'Changing & Bath', slug: 'changing-and-bath', href: base + 'changing-and-bath/', group: 'products', indent: true },
  { label: 'On the Go', slug: 'transport', href: base + 'transport/', group: 'products', indent: true },
  { label: 'The Playbook', slug: 'playbook', href: base + 'playbook/', group: 'guides' },
];

const allSlugs = nav.map((n) => n.slug);
const currentIndex = allSlugs.indexOf(currentSlug);
const prev = currentIndex > 0 ? nav[currentIndex - 1] : null;
const next = currentIndex < nav.length - 1 ? nav[currentIndex + 1] : null;

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

function navClass(slug: string, indent?: boolean) {
  const isActive = currentSlug === slug;
  const base = indent ? 'block pl-6 pr-3 py-1 text-[0.9rem]' : 'block px-3 py-1.5 text-[0.9rem] font-semibold';
  if (isActive) return base + ' rounded-lg bg-accent-light text-accent font-semibold';
  return base + ' rounded-lg text-gray-500 hover:bg-sidebar-hover hover:text-gray-800 transition-colors';
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet" />
  </head>
  <body class="text-gray-800 font-sans antialiased">

    <!-- Mobile header -->
    <header class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-sidebar-border px-4 h-14 flex items-center justify-between">
      <span class="text-sm font-bold text-gray-800">V.G.'s Baby Gear</span>
      <button id="menu-toggle" class="p-2 -mr-2 text-gray-400 hover:text-gray-600" aria-label="Toggle menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </header>

    <div class="min-h-screen">
      <!-- Sidebar -->
      <aside id="sidebar" class="hidden lg:block fixed top-0 left-0 bottom-0 w-52 bg-sidebar-bg border-r border-sidebar-border overflow-y-auto z-40">
        <div class="px-4 pt-6 pb-4">
          <span class="block text-[0.95rem] font-bold text-gray-800 tracking-tight leading-tight">V.G.'s Baby Gear</span>
          <p class="text-xs text-gray-400 mt-0.5">Notes from first-time parents</p>
        </div>
        <nav class="px-2 pb-8 space-y-0.5">
          <p class="px-3 pt-2 pb-1 text-[0.7rem] font-semibold text-gray-400 uppercase tracking-wider">Products</p>
          {nav.filter((item) => item.group === 'products').map((item) => (
            <a href={item.href} class={navClass(item.slug, item.indent)}>{item.label}</a>
          ))}
          <div class="my-2"></div>
          {nav.filter((item) => item.group === 'guides').map((item) => (
            <a href={item.href} class={navClass(item.slug)}>{item.label}</a>
          ))}
        </nav>
      </aside>

      <!-- Table of contents (right) -->
      {toc.length > 0 && (
        <aside class="hidden xl:block fixed top-0 right-0 bottom-0 w-56 overflow-y-auto py-10 px-4">
          <p class="text-[0.65rem] font-bold text-gray-400 uppercase tracking-widest mb-2">On this page</p>
          <nav class="space-y-0">
            {toc.map((h) => (
              <a
                href={'#' + h.slug}
                class={h.depth === 2
                  ? 'block text-[0.8rem] text-gray-400 hover:text-gray-700 font-medium py-0.5 leading-snug transition-colors'
                  : 'block text-[0.75rem] text-gray-300 hover:text-gray-500 pl-3 py-0.5 leading-snug transition-colors'}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </aside>
      )}

      <!-- Main content -->
      <main class="lg:ml-52 xl:mr-56">
        <div class="max-w-[680px] mx-auto px-6 sm:px-8 pt-18 lg:pt-10 pb-20">
          <article class="prose prose-gray">
            <slot />
          </article>

          {(prev || next) && (
            <nav class="mt-12 pt-6 border-t border-sidebar-border flex justify-between">
              {prev && (
                <a href={prev.href} class="group flex flex-col">
                  <span class="text-[0.65rem] text-gray-400 uppercase tracking-widest font-semibold">Previous</span>
                  <span class="text-sm text-accent group-hover:underline mt-0.5 font-medium">{prev.label}</span>
                </a>
              )}
              {next && (
                <a href={next.href} class="group flex flex-col text-right ml-auto">
                  <span class="text-[0.65rem] text-gray-400 uppercase tracking-widest font-semibold">Next</span>
                  <span class="text-sm text-accent group-hover:underline mt-0.5 font-medium">{next.label}</span>
                </a>
              )}
            </nav>
          )}
        </div>
      </main>
    </div>

    <script is:inline>
      document.getElementById('menu-toggle').addEventListener('click', function() {
        var sb = document.getElementById('sidebar');
        sb.classList.toggle('hidden');
        sb.classList.toggle('fixed');
        sb.classList.toggle('inset-0');
        sb.classList.toggle('w-full');
      });
    </script>
  </body>
</html>
